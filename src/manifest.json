{
  "manifest_version": 3,
  "name": "GIF Vault",
  "version": "1.2.4",
  "description": "Save GIFs and media links into a local vault.",
  "icons": {
    "16": "assets/icons/icon-light-16.png",
    "32": "assets/icons/icon-light-32.png",
    "48": "assets/icons/icon-light-48.png",
    "128": "assets/icons/icon-light-128.png"
  },
  "permissions": ["contextMenus", "storage", "offscreen", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GIF Vault",
    "default_icon": {
      "16": "assets/icons/icon-light-16.png",
      "32": "assets/icons/icon-light-32.png",
      "48": "assets/icons/icon-light-48.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "offscreen/offscreen.html",
        "offscreen/offscreen.js",
        "lib/db.js",
        "vendor/@ffmpeg/ffmpeg/esm/*",
        "vendor/@ffmpeg/core/esm/*",
        "vendor/@ffmpeg/util/esm/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

